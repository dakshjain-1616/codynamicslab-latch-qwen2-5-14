# ─────────────────────────────────────────────
# LATCH-Qwen2.5-14B-GGUF Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────

# HuggingFace token — required to download gated models (e.g. LATCH-Qwen2.5-14B)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Target model to quantize (HuggingFace repo ID or local path)
DEFAULT_MODEL=CoDynamicsLab/LATCH-Qwen2.5-14B

# Quantization format: Q4_K_M | Q4_K_S | Q5_K_M | Q8_0 | F16
DEFAULT_QUANT_TYPE=Q4_K_M

# Directory for all output files (GGUF, reports, JSON)
OUTPUT_DIR=outputs

# ─── llama.cpp ───────────────────────────────
# Root directory of your compiled llama.cpp build
LLAMA_CPP_DIR=/opt/llama.cpp

# Path to the llama-quantize binary (overrides LLAMA_CPP_DIR default)
LLAMA_QUANTIZE_BIN=/opt/llama.cpp/llama-quantize

# Path to the HF→GGUF conversion script (overrides LLAMA_CPP_DIR default)
LLAMA_CONVERT_SCRIPT=/opt/llama.cpp/convert_hf_to_gguf.py

# Path to the llama-cli binary for inference tests
LLAMA_CLI_BIN=/opt/llama.cpp/llama-cli

# ─── Quality Gate ────────────────────────────
# Maximum allowed relative perplexity delta between FP16 and quantized model.
# Build fails if delta exceeds this value. (0.05 = 5%)
PERPLEXITY_DELTA_THRESHOLD=0.05

# Number of test samples for perplexity evaluation (recommend ≥100 for production)
NUM_PERPLEXITY_SAMPLES=100

# Maximum token sequence length per sample during perplexity evaluation
MAX_SEQUENCE_LENGTH=512

# Whether to exit with error code when quality gate fails (true | false)
FAIL_ON_QUALITY_GATE=true

# ─── Mock / Dry-run Mode ─────────────────────
# Set to "true" to skip downloads and llama.cpp — uses a small proxy model instead.
# Auto-enabled when llama.cpp is not found.
MOCK_MODE=false

# Small proxy model used in mock mode for perplexity computation
# Must be a publicly accessible HuggingFace causal LM (≤1B params recommended for CPU)
# Trending small options: Qwen/Qwen3-0.6B, facebook/opt-125m, openai-community/gpt2
MOCK_PROXY_MODEL=Qwen/Qwen3-0.6B

# Simulated FP16 perplexity baseline (used when USE_REAL_PROXY_MODEL=false)
MOCK_FP16_PERPLEXITY=100.0

# Simulated Q4_K_M degradation factor used in mock mode (0.018 = 1.8% delta)
SIMULATED_QUANT_DELTA=0.018

# ─── Download Retry ──────────────────────────
# Maximum number of HuggingFace download attempts before giving up
DOWNLOAD_MAX_RETRIES=3

# Base delay in seconds between retry attempts (doubles each retry)
DOWNLOAD_RETRY_DELAY=2.0

# ─── Multi-Quant Sweep ───────────────────────
# Enable multi-quant sweep in demo (true | false)
COMPARE_QUANTS=false

# Comma-separated list of quant types to sweep (in order)
SWEEP_QUANT_TYPES=Q2_K,Q4_K_S,Q4_K_M,Q5_K_M,Q8_0

# VRAM budget for sweep recommendations (GB)
VRAM_BUDGET_GB=8.0

# ─── GGUF Inspection ─────────────────────────
# Parse and display GGUF binary header in demo/report (true | false)
INSPECT_GGUF=false

# ─── Run History ─────────────────────────────
# Whether to track pipeline runs in a JSONL history file (true | false)
TRACK_HISTORY=false

# Path to the JSONL run history log
HISTORY_FILE=outputs/run_history.jsonl

# Width (in characters) of the ASCII sparkline in history reports
SPARKLINE_WIDTH=20

# ─── Model Metadata ──────────────────────────
# Parameter count in billions — used for VRAM estimation
MODEL_PARAM_COUNT_B=14.7

# ─── Report Filenames ────────────────────────
# Name of the generated Markdown benchmark report
REPORT_FILENAME=quantization_report.md

# Name of the generated JSON results file
RESULTS_FILENAME=benchmark_results.json

# ─── Architecture Constants (Qwen2.5-14B defaults) ───────────────────────────
# Number of transformer layers (for KV cache estimation)
KV_LAYERS=48

# Number of GQA heads in the KV cache
KV_HEADS=8

# Attention head dimension
HEAD_DIM=128

# Activation and overhead memory estimate (GB)
ACTIVATION_OVERHEAD_GB=0.3
